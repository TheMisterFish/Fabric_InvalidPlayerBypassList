  },
  "license": "CC0-1.0",
  "icon": "assets/invalidplayerbypasslist/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.invalidplayerbypasslist.InvalidPlayerBypassList"
    ]
  },
  "mixins": [
    "invalidplayerbypasslist.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "minecraft": "1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
